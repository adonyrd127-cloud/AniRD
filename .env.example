# ── Seguridad JWT ──────────────────────────────────────────────────────────────
# Genera uno con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ── CORS ───────────────────────────────────────────────────────────────────────
# Orígenes permitidos separados por coma. Ej: http://100.110.101.28:8090,http://localhost:8090
ALLOWED_ORIGINS=

# ── API Keys del backend ───────────────────────────────────────────────────────
API_KEYS=

# ── Puertos (opcionales, estos son los defaults) ───────────────────────────────
BACKEND_PORT=3005
FRONTEND_PORT=8090
