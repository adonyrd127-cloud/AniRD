<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- Normal Icon Header -->
    <LinearLayout
        android:id="@+id/normal_header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <ImageView
            android:id="@+id/header_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="16dp"
            android:scaleType="fitCenter"
            app:tint="@color/tv_text_secondary" />

        <TextView
            android:id="@+id/header_label"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="@color/tv_text_secondary"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:includeFontPadding="false"/>

        <ImageView
            android:id="@+id/header_chevron"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_chevron_down"
            android:scaleType="fitCenter"
            android:visibility="gone"
            app:tint="@color/tv_text_secondary" />
    </LinearLayout>

    <!-- Following Header Item -->
    <LinearLayout
        android:id="@+id/following_header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="16dp"
            android:background="@color/tv_surface_card">
            
            <ImageView
                android:id="@+id/following_cover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            
            <TextView
                android:id="@+id/following_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/tv_text_secondary"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:includeFontPadding="false"/>
                
            <TextView
                android:id="@+id/following_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/tv_text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:fontFamily="sans-serif"
                android:includeFontPadding="false"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
