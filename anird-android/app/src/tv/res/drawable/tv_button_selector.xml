<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused state: Rojo AniRD con borde brillante -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/tv_primary"/>
            <stroke android:width="2dp" android:color="@color/tv_text_primary"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    <!-- Selected state: Servidor activo / Audio seleccionado -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/tv_primary"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/tv_primary_dark"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    
    <!-- Default state: Gris Oscuro -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/tv_surface_elevated"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
</selector>
